# ==========================================================================
# VoltMate environment. Copy to `.env` and fill in. NEVER commit the real .env.
# ==========================================================================

# --- App ---
APP_NAME=VoltMate
APP_ENV=production
DEBUG=false
API_V1_PREFIX=/api

# --- Host port (only voltmate-nginx is published) ---
VOLTMATE_HTTP_PORT=8101

# --- Public URL the frontend/QR codes should point to ---
PUBLIC_BASE_URL=http://localhost:8101
NEXT_PUBLIC_API_URL=/api

# --- Security ---
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-please-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- CORS (comma separated; * for all — tighten in production) ---
CORS_ORIGINS=*

# --- Database (internal to voltmate-network) ---
POSTGRES_USER=voltmate
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DB=voltmate
POSTGRES_HOST=voltmate-db
POSTGRES_PORT=5432

# --- Redis (rate limiting) ---
REDIS_URL=redis://voltmate-redis:6379/0

# --- Uploads ---
MAX_UPLOAD_SIZE_MB=5
UPLOAD_DIR=/app/uploads

# --- Rate limiting ---
REPORT_RATE_LIMIT=5/minute

# --- AI Assistant ---
# Leave USE_MOCK_AI=true to use the built-in rule-based assistant (no key needed).
# Set to false and fill AI_API_KEY/AI_API_BASE_URL to plug an OpenAI-compatible API later.
USE_MOCK_AI=true
AI_API_KEY=
AI_API_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
